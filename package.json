{
	"name": "playwright-fmwrk",
	"version": "1.0.0",
	"main": "index.js",
	"scripts": {
		"test": "playwright test",
		"test:dev": "ENV=dev playwright test",
		"test:staging": "ENV=staging playwright test",
		"test:prod": "ENV=prod playwright test",
		"test:headed": "playwright test --headed",
		"test:debug": "playwright test --debug",
		"test:ui": "playwright test --ui",
		"test:tag": "playwright test --grep",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf allure-results allure-report test-results logs/*.log ortoni-report",
		"prepare": "husky",
		"lint": "npx @biomejs/biome check --write",
		"commit": "npm run typecheck && npm run lint",
		"commitlint": "commitlint --edit",
		"report:ortoni": "npx ortoni-report show-report --dir ./ortoni-report custom-folder --file playwright.html --port 5500",
		"report:allure": "npx allure generate ./allure-results --clean && npx allure open ./allure-report",
		"report:html": "npx playwright show-report"
	},
	"keywords": [],
	"author": {
		"name": "Anirban Mishra",
		"email": "anirban.mishra@cloudkaptan.com"
	},
	"license": "ISC",
	"description": "",
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@playwright/test": "^1.59.1",
		"@types/chance": "^1.1.7",
		"@types/node": "^25.5.2",
		"allure-commandline": "^2.38.1",
		"allure-playwright": "^3.7.0",
		"chance": "^1.1.13",
		"dotenv": "^17.2.3",
		"husky": "^9.1.7",
		"ortoni-report": "^4.0.8",
		"speakeasy": "^2.0.0",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.2",
		"winston": "^3.19.0",
		"winston-daily-rotate-file": "^5.0.0"
	}
}
